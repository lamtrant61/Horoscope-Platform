{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "types": [
      "@nuxt/types",
      "@pinia/nuxt",
      "@nuxtjs/tailwindcss",
    ],
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./*"]
    }
  },
  // "include": [
  //   ".nuxt/**/*.ts"        // 👈 quan trọng
  // ],
}
