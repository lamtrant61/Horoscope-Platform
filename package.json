{
  "name": "@horoscope/theme",
  "version": "2.0.12",
  "description": "Horoscope Theme",
  "author": "lamtrant61",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./nuxt.config.ts",
  "repository": {
    "type": "git",
    "url": "git://github.com/lamtrant61/Horoscope-Nuxt3"
  },
  "files": [
    "assets",
    "components",
    "composables",
    "layouts",
    "modules",
    "pages",
    "public",
    "stores",
    "app.config.ts",
    "app.vue",
    "nuxt.config.ts",
    "nuxt.schema.ts",
    "tailwind.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "nuxt dev --no-clear",
    "dev-host": "nuxt dev --host 0.0.0.0 --no-clear",
    "build": "nuxt build",
    "dev-app": "nuxt dev ./app --no-clear",
    "generate": "nuxt generate ./app",
    "preview": "nuxt preview ./app",
    "postinstall": "nuxt prepare ./app",
    "dev:starter": "nuxt dev ./examples/starter",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:coverage": "vitest run --coverage --configLoader runner",
    "lint": "eslint --ext \".ts,.js,.vue\" --ignore-path .eslintignore .",
    "lint:fix": "eslint --fix --ext \".ts,.js,.vue\" --ignore-path .eslintignore .",
    "release": "release-it",
    "sequelize-migrate": "npx sequelize-cli db:create && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
    "sequelize-undo": "npx sequelize-cli db:migrate:undo:all",
    "sequelize-seed": "npx sequelize-cli db:seed:all --debug"
  },
  "dependencies": {
    "@nuxt/content": "^2.9.0",
    "@nuxt/devtools": "^1.0.0",
    "@nuxtjs/color-mode": "^3.3.0",
    "@nuxtjs/sitemap": "^7.4.7",
    "@nuxtjs/tailwindcss": "^6.8.1",
    "@pinia/nuxt": "^0.5.1",
    "@types/bcrypt": "^5.0.2",
    "@vueuse/core": "^10.5.0",
    "@vueuse/nuxt": "^10.5.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "element-plus": "^2.10.1",
    "html2canvas": "^1.4.1",
    "iztro": "^2.5.0",
    "jsonwebtoken": "^9.0.2",
    "mitt": "^3.0.1",
    "mysql2": "^3.14.1",
    "node-telegram-bot-api": "^0.66.0",
    "nuxt-headlessui": "^1.1.4",
    "nuxt-icon": "^0.6.1",
    "openai": "^5.19.1",
    "pinia": "^2.1.7",
    "sass": "^1.69.5",
    "sequelize": "^6.37.7",
    "stringify": "^5.2.0",
    "tailwindcss": "^3.3.5",
    "unplugin-vue-components": "^0.25.2",
    "viet-lunar-calendar": "^1.0.9",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nuxt/types": "^2.18.1",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/robots": "^5.5.6",
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "consola": "^3.2.3",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "happy-dom": "^20.10.6",
    "nuxt": "^3.8.0",
    "prettier": "^3.0.3",
    "release-it": "^16.2.1",
    "serve": "^14.2.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.9",
    "vue-tsc": "1.8.22"
  },
  "release-it": {
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "git": {
      "commitMessage": "chore(release): release v${version}"
    }
  }
}
